# ============================================
# URL FEATURE EXTRACTOR
# ============================================

class URLFeatureExtractor:
    """
    Extract numerical features from URLs for ML classification
    """
    
    def __init__(self):
        self.suspicious_tlds = {
            'tk', 'ml', 'ga', 'cf', 'xyz', 'top', 'club', 'online', 
            'site', 'web', 'work', 'review', 'stream', 'download',
            'bid', 'trade', 'webcam', 'win', 'science', 'date', 'kim',
            'men', 'loan', 'click', 'link', 'download', 'review'
        }
        
        self.suspicious_keywords = [
            'secure', 'login', 'signin', 'verify', 'account', 'update',
            'confirm', 'banking', 'paypal', 'apple', 'microsoft', 'google',
            'facebook', 'instagram', 'amazon', 'ebay', 'netflix', 'pay',
            'wallet', 'bitcoin', 'crypto', 'blockchain', 'support',
            'customer', 'service', 'help', 'claim', 'prize', 'winner',
            'free', 'bonus', 'promo', 'discount', 'offer', 'deal',
            'password', 'credit', 'card', 'ssn', 'social security'
        ]
        
        # Compile regex patterns
        self.ip_pattern = re.compile(r'^\d+\.\d+\.\d+\.\d+$')
        self.hex_pattern = re.compile(r'%[0-9a-fA-F]{2}')
        self.multi_dot_pattern = re.compile(r'\.{2,}')
    
    def extract_features(self, url):
        """
        Extract 30+ features from URL
        
        Returns:
            Dictionary of numerical features
        """
        features = {}
        
        # Parse URL
        parsed = urlparse(url)
        extracted = tldextract.extract(url)
        
        domain = extracted.domain
        suffix = extracted.suffix
        subdomain = extracted.subdomain
        full_domain = f"{domain}.{suffix}" if domain and suffix else ""
        
        # 1. URL length features
        features['url_length'] = len(url)
        features['domain_length'] = len(full_domain)
        features['path_length'] = len(parsed.path)
        features['query_length'] = len(parsed.query)
        
        # 2. Special character counts
        features['num_dots'] = url.count('.')
        features['num_hyphens'] = url.count('-')
        features['num_underscores'] = url.count('_')
        features['num_slashes'] = url.count('/')
        features['num_question_marks'] = url.count('?')
        features['num_equals'] = url.count('=')
        features['num_ampersands'] = url.count('&')
        features['num_at'] = url.count('@')
        features['num_percent'] = url.count('%')
        
        # 3. Digit and letter counts
        features['num_digits'] = sum(c.isdigit() for c in url)
        features['num_letters'] = sum(c.isalpha() for c in url)
        features['digit_ratio'] = features['num_digits'] / (len(url) + 1)
        
        # 4. Suspicious indicators
        features['has_ip'] = 1 if self.ip_pattern.match(parsed.netloc.split(':')[0]) else 0
        features['has_port'] = 1 if parsed.port else 0
        features['has_hex_chars'] = 1 if self.hex_pattern.search(url) else 0
        features['has_multi_dots'] = 1 if self.multi_dot_pattern.search(url) else 0
        
        # 5. TLD analysis
        features['suspicious_tld'] = 1 if suffix in self.suspicious_tlds else 0
        features['tld_length'] = len(suffix)
        
        # 6. Subdomain analysis
        features['subdomain_length'] = len(subdomain)
        features['subdomain_count'] = len(subdomain.split('.')) if subdomain else 0
        features['has_www'] = 1 if 'www' in subdomain else 0
        
        # 7. Path analysis
        features['path_depth'] = len([p for p in parsed.path.split('/') if p])
        features['has_extension'] = 1 if '.' in parsed.path.split('/')[-1] else 0
        
        # 8. Query parameter analysis
        params = parse_qs(parsed.query)
        features['num_params'] = len(params)
        features['max_param_length'] = max([len(v[0]) for v in params.values()]) if params else 0
        
        # 9. Keyword matching
        url_lower = url.lower()
        features['suspicious_keywords'] = sum(
            1 for kw in self.suspicious_keywords if kw in url_lower
        )
        
        # 10. Entropy (randomness)
        features['entropy'] = self._calculate_entropy(url)
        
        # 11. HTTPS check
        features['is_https'] = 1 if parsed.scheme == 'https' else 0
        
        # 12. Domain age features (if available)
        features['domain_age_days'] = -1  # Will be updated if WHOIS available
        
        return features
    
    def _calculate_entropy(self, text):
        """Calculate Shannon entropy of string"""
        if not text:
            return 0.0
        
        entropy = 0.0
        for i in range(256):
            char = chr(i)
            freq = text.count(char)
            if freq > 0:
                freq = float(freq) / len(text)
                entropy -= freq * np.log2(freq)
        
        return entropy


# ============================================
# ADVANCED FEATURE EXTRACTOR (with WHOIS)
# ============================================

class AdvancedURLFeatureExtractor(URLFeatureExtractor):
    """
    Advanced feature extractor that includes WHOIS and network features
    """
    
    def extract_features_with_whois(self, url, timeout=5):
        """Extract features including WHOIS data"""
        features = self.extract_features(url)
        
        parsed = urlparse(url)
        extracted = tldextract.extract(url)
        domain = f"{extracted.domain}.{extracted.suffix}" if extracted.domain and extracted.suffix else ""
        
        if domain:
            # Domain age feature
            try:
                domain_info = whois.whois(domain)
                
                # Creation date
                creation_date = domain_info.creation_date
                if isinstance(creation_date, list):
                    creation_date = creation_date[0]
                
                if creation_date:
                    age_days = (datetime.now() - creation_date).days
                    features['domain_age_days'] = age_days
                    features['domain_age_months'] = age_days / 30
                    features['domain_age_years'] = age_days / 365
                else:
                    features['domain_age_days'] = -1
                    features['domain_age_months'] = -1
                    features['domain_age_years'] = -1
                
                # Expiration date
                expiration_date = domain_info.expiration_date
                if isinstance(expiration_date, list):
                    expiration_date = expiration_date[0]
                
                if expiration_date:
                    days_to_expiry = (expiration_date - datetime.now()).days
                    features['days_to_expiry'] = days_to_expiry
                else:
                    features['days_to_expiry'] = -1
                
                # Registrar
                features['has_registrar'] = 1 if domain_info.registrar else 0
                
            except Exception as e:
                features['domain_age_days'] = -2  # WHOIS lookup failed
                features['domain_age_months'] = -2
                features['domain_age_years'] = -2
                features['days_to_expiry'] = -2
                features['has_registrar'] = 0
        
        return features


# ============================================
# SYNTHETIC DATA GENERATOR
# ============================================

class SyntheticURLDataGenerator:
    """
    Generate synthetic URL data for training
    """
    
    def __init__(self, n_samples=10000):
        self.n_samples = n_samples
        self.feature_extractor = URLFeatureExtractor()
        
        # Legitimate URL patterns
        self.legitimate_domains = [
            'google', 'facebook', 'amazon', 'microsoft', 'apple',
            'netflix', 'spotify', 'github', 'stackoverflow', 'wikipedia',
            'youtube', 'twitter', 'linkedin', 'instagram', 'reddit'
        ]
        
        # Suspicious domains for phishing
        self.suspicious_domains = [
            'secure-google', 'facebook-login', 'amazon-security', 'paypal-verify',
            'apple-id', 'microsoft-account', 'netflix-billing', 'bankofamerica',
            'wellsfargo', 'chase', 'capitalone', 'citibank'
        ]
        
        self.tlds = ['com', 'org', 'net', 'io', 'co', 'uk', 'de', 'fr', 'jp', 'cn']
        self.suspicious_tlds = ['tk', 'ml', 'ga', 'cf', 'xyz', 'top', 'club']
    
    def generate_legitimate_url(self):
        """Generate a legitimate URL"""
        domain = np.random.choice(self.legitimate_domains)
        tld = np.random.choice(self.tlds)
        
        # Random path
        paths = ['', 'home', 'about', 'products', 'services', 'blog', 'contact']
        path = np.random.choice(paths)
        
        if path and np.random.random() > 0.3:
            url = f"https://www.{domain}.{tld}/{path}"
        else:
            url = f"https://www.{domain}.{tld}"
        
        return url
    
    def generate_phishing_url(self):
        """Generate a phishing URL"""
        # Option 1: Typosquatting
        if np.random.random() > 0.5:
            domain = np.random.choice(self.legitimate_domains)
            # Add common typo
            if np.random.random() > 0.5:
                domain = domain.replace('o', '0').replace('l', '1')
            else:
                domain = domain + '-secure'
        else:
            domain = np.random.choice(self.suspicious_domains)
        
        tld = np.random.choice(self.suspicious_tlds + self.tlds)
        
        # Add suspicious elements
        url = f"http://{domain}.{tld}"
        
        # Add login path
        if np.random.random() > 0.3:
            url += "/login.php"
        
        # Add query parameters
        if np.random.random() > 0.5:
            url += "?username=admin&password=12345"
        
        return url
    
    def generate_dataset(self):
        """Generate synthetic dataset"""
        print("Generating synthetic URL dataset...")
        
        urls = []
        labels = []
        
        # Generate legitimate URLs
        for _ in range(self.n_samples // 2):
            urls.append(self.generate_legitimate_url())
            labels.append(0)  # 0 = legitimate
        
        # Generate phishing URLs
        for _ in range(self.n_samples // 2):
            urls.append(self.generate_phishing_url())
            labels.append(1)  # 1 = phishing
        
        # Extract features
        print("Extracting features...")
        features_list = []
        for i, url in enumerate(urls):
            if i % 1000 == 0:
                print(f"  Processed {i}/{len(urls)} URLs")
            features = self.feature_extractor.extract_features(url)
            features_list.append(features)
        
        # Convert to DataFrame
        df = pd.DataFrame(features_list)
        df['url'] = urls
        df['label'] = labels
        
        return df


# ============================================
# MODEL TRAINING
# ============================================

def train_url_classifier():
    """Train URL classifier model"""
    
    print("=" * 60)
    print("TRAINING URL CLASSIFIER MODEL")
    print("=" * 60)
    
    # Configuration
    config = {
        'n_samples': 20000,
        'test_size': 0.2,
        'random_state': 42,
        'model_save_path': 'models/url_classifier.pkl',
        'scaler_save_path': 'models/url_scaler.pkl',
        'feature_names_path': 'models/url_features.json'
    }
    
    # Generate synthetic data
    print("\n1️⃣ Generating synthetic URL dataset...")
    generator = SyntheticURLDataGenerator(n_samples=config['n_samples'])
    df = generator.generate_dataset()
    
    print(f"\n📊 Dataset shape: {df.shape}")
    print(f"   Legitimate URLs: {(df['label'] == 0).sum()}")
    print(f"   Phishing URLs: {(df['label'] == 1).sum()}")
    
    # Prepare features
    feature_columns = [col for col in df.columns if col not in ['url', 'label']]
    X = df[feature_columns].values
    y = df['label'].values
    
    # Save feature names
    with open(config['feature_names_path'], 'w') as f:
        json.dump(feature_columns, f, indent=2)
    
    # Split data
    X_train, X_test, y_train, y_test = train_test_split(
        X, y, test_size=config['test_size'], random_state=config['random_state'], stratify=y
    )
    
    print(f"\n2️⃣ Training set: {X_train.shape[0]} samples")
    print(f"   Test set: {X_test.shape[0]} samples")
    
    # Scale features
    scaler = StandardScaler()
    X_train_scaled = scaler.fit_transform(X_train)
    X_test_scaled = scaler.transform(X_test)
    
    # Save scaler
    joblib.dump(scaler, config['scaler_save_path'])
    print(f"\n✅ Scaler saved to {config['scaler_save_path']}")
    
    # ========================================
    # Train multiple models
    # ========================================
    
    models = {
        'Random Forest': RandomForestClassifier(
            n_estimators=100,
            max_depth=10,
            random_state=config['random_state']
        ),
        'Gradient Boosting': GradientBoostingClassifier(
            n_estimators=100,
            max_depth=5,
            random_state=config['random_state']
        ),
        'Logistic Regression': LogisticRegression(
            max_iter=1000,
            random_state=config['random_state']
        ),
        'SVM': SVC(
            kernel='rbf',
            probability=True,
            random_state=config['random_state']
        ),
        'Decision Tree': DecisionTreeClassifier(
            max_depth=10,
            random_state=config['random_state']
        ),
        'KNN': KNeighborsClassifier(
            n_neighbors=5
        ),
        'Naive Bayes': GaussianNB()
    }
    
    results = {}
    
    print("\n3️⃣ Training individual models...")
    
    for name, model in models.items():
        print(f"\n   Training {name}...")
        model.fit(X_train_scaled, y_train)
        
        # Predictions
        y_pred = model.predict(X_test_scaled)
        y_prob = model.predict_proba(X_test_scaled)[:, 1] if hasattr(model, 'predict_proba') else None
        
        # Metrics
        accuracy = accuracy_score(y_test, y_pred)
        precision = precision_score(y_test, y_pred)
        recall = recall_score(y_test, y_pred)
        f1 = f1_score(y_test, y_pred)
        
        results[name] = {
            'model': model,
            'accuracy': accuracy,
            'precision': precision,
            'recall': recall,
            'f1': f1,
            'y_pred': y_pred,
            'y_prob': y_prob
        }
        
        print(f"      Accuracy: {accuracy:.4f}, Precision: {precision:.4f}, "
              f"Recall: {recall:.4f}, F1: {f1:.4f}")
    
    # ========================================
    # Ensemble Model
    # ========================================
    
    print("\n4️⃣ Creating ensemble model...")
    
    # Create voting classifier
    estimators = [
        ('rf', models['Random Forest']),
        ('gb', models['Gradient Boosting']),
        ('lr', models['Logistic Regression']),
        ('svm', models['SVM'])
    ]
    
    ensemble = VotingClassifier(
        estimators=estimators,
        voting='soft'
    )
    
    ensemble.fit(X_train_scaled, y_train)
    
    # Evaluate ensemble
    y_pred_ensemble = ensemble.predict(X_test_scaled)
    y_prob_ensemble = ensemble.predict_proba(X_test_scaled)[:, 1]
    
    ensemble_accuracy = accuracy_score(y_test, y_pred_ensemble)
    ensemble_precision = precision_score(y_test, y_pred_ensemble)
    ensemble_recall = recall_score(y_test, y_pred_ensemble)
    ensemble_f1 = f1_score(y_test, y_pred_ensemble)
    ensemble_auc = roc_auc_score(y_test, y_prob_ensemble)
    
    print(f"\n   Ensemble Results:")
    print(f"      Accuracy: {ensemble_accuracy:.4f}")
    print(f"      Precision: {ensemble_precision:.4f}")
    print(f"      Recall: {ensemble_recall:.4f}")
    print(f"      F1 Score: {ensemble_f1:.4f}")
    print(f"      AUC-ROC: {ensemble_auc:.4f}")
    
    results['Ensemble'] = {
        'model': ensemble,
        'accuracy': ensemble_accuracy,
        'precision': ensemble_precision,
        'recall': ensemble_recall,
        'f1': ensemble_f1,
        'auc': ensemble_auc
    }
    
    # ========================================
    # Hyperparameter Tuning (Random Forest)
    # ========================================
    
    print("\n5️⃣ Tuning Random Forest hyperparameters...")
    
    param_grid = {
        'n_estimators': [50, 100, 200],
        'max_depth': [5, 10, 15, None],
        'min_samples_split': [2, 5, 10],
        'min_samples_leaf': [1, 2, 4]
    }
    
    grid_search = GridSearchCV(
        RandomForestClassifier(random_state=config['random_state']),
        param_grid,
        cv=5,
        scoring='f1',
        n_jobs=-1,
        verbose=1
    )
    
    grid_search.fit(X_train_scaled, y_train)
    
    print(f"\n   Best parameters: {grid_search.best_params_}")
    print(f"   Best cross-val score: {grid_search.best_score_:.4f}")
    
    best_rf = grid_search.best_estimator_
    y_pred_best = best_rf.predict(X_test_scaled)
    best_f1 = f1_score(y_test, y_pred_best)
    
    print(f"   Test F1 score: {best_f1:.4f}")
    
    # ========================================
    # Feature Importance
    # ========================================
    
    print("\n6️⃣ Feature Importance Analysis...")
    
    if hasattr(best_rf, 'feature_importances_'):
        importances = best_rf.feature_importances_
        indices = np.argsort(importances)[::-1]
        
        print("\n   Top 10 most important features:")
        for i in range(10):
            if i < len(indices):
                print(f"      {i+1}. {feature_columns[indices[i]]}: {importances[indices[i]]:.4f}")
    
    # ========================================
    # Save the best model
    # ========================================
    
    # Use tuned Random Forest as final model
    final_model = best_rf
    
    # Save model
    joblib.dump(final_model, config['model_save_path'])
    print(f"\n✅ Model saved to {config['model_save_path']}")
    
    # Save results summary
    results_summary = {
        'ensemble': {
            'accuracy': ensemble_accuracy,
            'precision': ensemble_precision,
            'recall': ensemble_recall,
            'f1': ensemble_f1,
            'auc': ensemble_auc
        },
        'best_rf': {
            'params': grid_search.best_params_,
            'f1': best_f1
        },
        'feature_names': feature_columns,
        'n_features': len(feature_columns)
    }
    
    with open('models/url_classifier_results.json', 'w') as f:
        json.dump(results_summary, f, indent=2)
    
    print("\n" + "=" * 60)
    print("✅ TRAINING COMPLETE!")
    print("=" * 60)
    
    return config['model_save_path']


# ============================================
# MODEL VERIFICATION
# ============================================

def verify_url_classifier(model_path='models/url_classifier.pkl'):
    """Verify URL classifier model"""
    
    print("=" * 60)
    print("VERIFYING URL CLASSIFIER MODEL")
    print("=" * 60)
    
    # Check if file exists
    if not Path(model_path).exists():
        print(f"❌ Model file not found: {model_path}")
        print("\nPlease run training script first:")
        print("  python training/train_url_classifier.py")
        return False
    
    # Check file size
    size = Path(model_path).stat().st_size / (1024 * 1024)
    print(f"📁 File size: {size:.2f} MB")
    
    try:
        # Load model
        model = joblib.load(model_path)
        print("✅ Model loaded successfully")
        
        # Load scaler
        scaler = joblib.load('models/url_scaler.pkl')
        print("✅ Scaler loaded successfully")
        
        # Load feature names
        with open('models/url_features.json', 'r') as f:
            feature_names = json.load(f)
        print(f"✅ Feature names loaded ({len(feature_names)} features)")
        
        # Test with sample URLs
        print(f"\n🧪 Testing with sample URLs...")
        
        extractor = URLFeatureExtractor()
        
        test_urls = [
            # Legitimate URLs
            "https://www.google.com/search?q=python",
            "https://github.com/username/repository",
            "https://www.amazon.com/product-name/dp/B08N5WRWNW",
            
            # Suspicious URLs
            "http://secure-google-login.com/account/verify",
            "https://paypal-verification.tk/login.php?user=test",
            "http://apple-id-verify.xyz/signin",
            "https://amazon-security.club/update-payment",
            "http://bankofamerica-secure-login.ga"
        ]
        
        expected = [0, 0, 0, 1, 1, 1, 1, 1]  # 0=legitimate, 1=phishing
        
        for i, url in enumerate(test_urls):
            # Extract features
            features_dict = extractor.extract_features(url)
            
            # Convert to array in correct order
            features = np.array([[features_dict[name] for name in feature_names]])
            
            # Scale
            features_scaled = scaler.transform(features)
            
            # Predict
            pred = model.predict(features_scaled)[0]
            proba = model.predict_proba(features_scaled)[0]
            
            pred_label = "LEGITIMATE" if pred == 0 else "PHISHING"
            expected_label = "LEGITIMATE" if expected[i] == 0 else "PHISHING"
            
            print(f"\n   URL {i+1}: {url[:60]}...")
            print(f"      Prediction: {pred_label} (Prob: {proba[1]:.4f})")
            print(f"      Expected: {expected_label}")
            print(f"      {'✅ CORRECT' if pred == expected[i] else '❌ WRONG'}")
        
        return True
        
    except Exception as e:
        print(f"❌ Error verifying model: {str(e)}")
        import traceback
        traceback.print_exc()
        return False


# ============================================
# MODEL EXPORT (ONNX)
# ============================================

def export_to_onnx(model_path='models/url_classifier.pkl',
                   onnx_path='models/url_classifier.onnx'):
    """Export model to ONNX format"""
    
    print("=" * 60)
    print("EXPORTING URL CLASSIFIER TO ONNX")
    print("=" * 60)
    
    try:
        import skl2onnx
        from skl2onnx import convert_sklearn
        from skl2onnx.common.data_types import FloatTensorType
        
        # Load model
        model = joblib.load(model_path)
        
        # Get feature count
        with open('models/url_features.json', 'r') as f:
            feature_names = json.load(f)
        
        n_features = len(feature_names)
        
        # Define input type
        initial_type = [('float_input', FloatTensorType([None, n_features]))]
        
        # Convert
        onnx_model = convert_sklearn(model, initial_types=initial_type)
        
        # Save
        with open(onnx_path, 'wb') as f:
            f.write(onnx_model.SerializeToString())
        
        print(f"✅ Model exported to {onnx_path}")
        
        # Show file size
        size = Path(onnx_path).stat().st_size / (1024 * 1024)
        print(f"📁 ONNX file size: {size:.2f} MB")
        
        return onnx_path
        
    except Exception as e:
        print(f"❌ Export error: {str(e)}")
        return None


# ============================================
# MAIN EXECUTION
# ============================================

if __name__ == "__main__":
    import argparse
    
    parser = argparse.ArgumentParser(description='Train/Verify URL Classifier Model')
    parser.add_argument('--train', action='store_true', help='Train the model')
    parser.add_argument('--verify', action='store_true', help='Verify existing model')
    parser.add_argument('--export', action='store_true', help='Export to ONNX format')
    
    args = parser.parse_args()
    
    if args.train:
        train_url_classifier()
    
    if args.verify:
        verify_url_classifier()
    
    if args.export:
        export_to_onnx()
    
    if not any([args.train, args.verify, args.export]):
        print("No action specified. Available options:")
        print("  --train     Train the model")
        print("  --verify    Verify existing model")
        print("  --export    Export to ONNX format")