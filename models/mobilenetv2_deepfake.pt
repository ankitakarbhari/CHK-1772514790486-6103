```python
# training/train_mobilenet.py
"""
Training script for MobileNetV2 Deepfake Detection Model
Generates mobilenetv2_deepfake.pt file
Optimized for real-time detection (15-20 FPS)
"""

import os
import sys
import torch
import torch.nn as nn
import torch.optim as optim
from torch.utils.data import DataLoader, Dataset
from torchvision import transforms, models
import numpy as np
from pathlib import Path
from PIL import Image
import albumentations as A
from albumentations.pytorch import ToTensorV2

# Add project root to path
sys.path.append(str(Path(__file__).parent.parent))

from app.models.mobilenet_model import PyTorchMobileNet, MobileNetFactory


# ============================================
# CUSTOM DATASET
# ============================================

class DeepfakeDataset(Dataset):
    """Dataset for deepfake training with augmentations"""
    
    def __init__(self, real_paths, fake_paths, transform=None, img_size=224):
        self.real_paths = real_paths
        self.fake_paths = fake_paths
        self.transform = transform
        self.img_size = img_size
        
        # Create labels (0=real, 1=fake)
        self.image_paths = real_paths + fake_paths
        self.labels = [0] * len(real_paths) + [1] * len(fake_paths)
        
        # Basic transform if none provided
        if transform is None:
            self.transform = transforms.Compose([
                transforms.Resize((img_size, img_size)),
                transforms.ToTensor(),
                transforms.Normalize(mean=[0.485, 0.456, 0.406], 
                                   std=[0.229, 0.224, 0.225])
            ])
    
    def __len__(self):
        return len(self.image_paths)
    
    def __getitem__(self, idx):
        path = self.image_paths[idx]
        label = self.labels[idx]
        
        try:
            # Load image
            image = Image.open(path).convert('RGB')
            
            # Apply transforms
            if self.transform:
                image = self.transform(image)
            
            return image, label
            
        except Exception as e:
            print(f"Error loading {path}: {str(e)}")
            # Return a random tensor as fallback
            return torch.randn(3, self.img_size, self.img_size), label


# ============================================
# ADVANCED AUGMENTATIONS
# ============================================

def get_augmentations(img_size=224, train=True):
    """Get data augmentations for training"""
    
    if train:
        return A.Compose([
            A.RandomResizedCrop(img_size, img_size, scale=(0.8, 1.0)),
            A.HorizontalFlip(p=0.5),
            A.Rotate(limit=15, p=0.3),
            A.OneOf([
                A.GaussianBlur(blur_limit=3, p=0.3),
                A.MedianBlur(blur_limit=3, p=0.3),
                A.GaussNoise(var_limit=(10.0, 30.0), p=0.2),
            ], p=0.3),
            A.OneOf([
                A.CLAHE(clip_limit=2, p=0.3),
                A.RandomBrightnessContrast(brightness_limit=0.2, contrast_limit=0.2, p=0.3),
                A.HueSaturationValue(hue_shift_limit=10, sat_shift_limit=20, val_shift_limit=10, p=0.3),
            ], p=0.3),
            A.CoarseDropout(max_holes=8, max_height=32, max_width=32, fill_value=0, p=0.2),
            A.Normalize(mean=[0.485, 0.456, 0.406], std=[0.229, 0.224, 0.225]),
            ToTensorV2()
        ])
    else:
        return A.Compose([
            A.Resize(img_size, img_size),
            A.Normalize(mean=[0.485, 0.456, 0.406], std=[0.229, 0.224, 0.225]),
            ToTensorV2()
        ])


# ============================================
# METRICS CALCULATION
# ============================================

class AverageMeter:
    """Computes and stores the average and current value"""
    def __init__(self):
        self.reset()
    
    def reset(self):
        self.val = 0
        self.avg = 0
        self.sum = 0
        self.count = 0
    
    def update(self, val, n=1):
        self.val = val
        self.sum += val * n
        self.count += n
        self.avg = self.sum / self.count


def calculate_accuracy(output, target):
    """Calculate accuracy"""
    with torch.no_grad():
        pred = output.argmax(dim=1)
        correct = pred.eq(target).sum().item()
        return correct / target.size(0)


def calculate_precision_recall(output, target):
    """Calculate precision and recall"""
    with torch.no_grad():
        pred = output.argmax(dim=1)
        
        # For binary classification
        tp = ((pred == 1) & (target == 1)).sum().item()
        fp = ((pred == 1) & (target == 0)).sum().item()
        fn = ((pred == 0) & (target == 1)).sum().item()
        
        precision = tp / (tp + fp + 1e-8)
        recall = tp / (tp + fn + 1e-8)
        f1 = 2 * precision * recall / (precision + recall + 1e-8)
        
        return precision, recall, f1


# ============================================
# TRAINING FUNCTION
# ============================================

def train_mobilenet():
    """Train MobileNetV2 model for deepfake detection"""
    
    # Configuration
    config = {
        'model_size': 'v2',  # 'v2' or 'v3'
        'use_custom': True,   # Use custom architecture with attention
        'num_classes': 2,
        'batch_size': 64,     # MobileNet is lightweight
        'epochs': 50,
        'learning_rate': 0.001,
        'weight_decay': 1e-4,
        'device': 'cuda' if torch.cuda.is_available() else 'cpu',
        'num_workers': 4,
        'img_size': 224,
        'model_save_path': 'models/mobilenetv2_deepfake.pt',
        'checkpoint_dir': 'checkpoints/mobilenet',
    }
    
    print("=" * 60)
    print("TRAINING MOBILENETV2 DEEPFAKE DETECTOR")
    print("=" * 60)
    print(f"Configuration: {config}")
    
    # Create checkpoint directory
    os.makedirs(config['checkpoint_dir'], exist_ok=True)
    
    # Initialize model
    print("\n1️⃣ Initializing model...")
    model = MobileNetFactory.create_pytorch_model(
        model_size=config['model_size'],
        use_custom=config['use_custom'],
        num_classes=config['num_classes'],
        device=config['device']
    )
    
    print(f"   Model parameters: {model.count_parameters():,}")
    print(f"   Using device: {config['device']}")
    
    # Loss function and optimizer
    criterion = nn.CrossEntropyLoss()
    optimizer = optim.Adam(
        model.model.parameters(),
        lr=config['learning_rate'],
        weight_decay=config['weight_decay']
    )
    
    # Learning rate scheduler
    scheduler = optim.lr_scheduler.ReduceLROnPlateau(
        optimizer, mode='min', factor=0.5, patience=5, verbose=True
    )
    
    # TODO: Load your datasets
    print("\n⚠️  Please update the training script with your dataset paths")
    print("Example dataset structure:")
    print("""
    datasets/
    ├── train/
    │   ├── real/
    │   │   ├── img1.jpg
    │   │   ├── img2.jpg
    │   │   └── ...
    │   └── fake/
    │       ├── fake1.jpg
    │       ├── fake2.jpg
    │       └── ...
    └── val/
        ├── real/
        └── fake/
    """)
    
    # For demonstration, create dummy data
    print("\n📊 Creating dummy dataset for demonstration...")
    
    # Create dummy image paths
    dummy_real_paths = ['dummy_real.jpg'] * 500
    dummy_fake_paths = ['dummy_fake.jpg'] * 500
    
    # Create datasets
    train_transform = get_augmentations(config['img_size'], train=True)
    val_transform = get_augmentations(config['img_size'], train=False)
    
    train_dataset = DeepfakeDataset(
        real_paths=dummy_real_paths[:400],
        fake_paths=dummy_fake_paths[:400],
        transform=train_transform
    )
    
    val_dataset = DeepfakeDataset(
        real_paths=dummy_real_paths[400:],
        fake_paths=dummy_fake_paths[400:],
        transform=val_transform
    )
    
    # Create data loaders
    train_loader = DataLoader(
        train_dataset,
        batch_size=config['batch_size'],
        shuffle=True,
        num_workers=config['num_workers'],
        pin_memory=True
    )
    
    val_loader = DataLoader(
        val_dataset,
        batch_size=config['batch_size'],
        shuffle=False,
        num_workers=config['num_workers'],
        pin_memory=True
    )
    
    print(f"   Train samples: {len(train_dataset)}")
    print(f"   Val samples: {len(val_dataset)}")
    
    # Training loop
    print("\n2️⃣ Starting training...")
    best_val_acc = 0.0
    
    for epoch in range(config['epochs']):
        # Training phase
        model.model.train()
        train_losses = AverageMeter()
        train_acc = AverageMeter()
        
        for batch_idx, (images, labels) in enumerate(train_loader):
            images = images.to(config['device'])
            labels = labels.to(config['device'])
            
            # Forward pass
            optimizer.zero_grad()
            outputs = model.model(images)
            loss = criterion(outputs, labels)
            
            # Backward pass
            loss.backward()
            optimizer.step()
            
            # Calculate accuracy
            acc = calculate_accuracy(outputs, labels)
            
            # Update metrics
            train_losses.update(loss.item(), images.size(0))
            train_acc.update(acc, images.size(0))
            
            if batch_idx % 50 == 0:
                print(f"   Epoch [{epoch+1}/{config['epochs']}] "
                      f"Batch [{batch_idx}/{len(train_loader)}] "
                      f"Loss: {train_losses.avg:.4f} Acc: {train_acc.avg:.4f}")
        
        # Validation phase
        model.model.eval()
        val_losses = AverageMeter()
        val_acc = AverageMeter()
        val_precision = AverageMeter()
        val_recall = AverageMeter()
        val_f1 = AverageMeter()
        
        with torch.no_grad():
            for images, labels in val_loader:
                images = images.to(config['device'])
                labels = labels.to(config['device'])
                
                outputs = model.model(images)
                loss = criterion(outputs, labels)
                
                acc = calculate_accuracy(outputs, labels)
                precision, recall, f1 = calculate_precision_recall(outputs, labels)
                
                val_losses.update(loss.item(), images.size(0))
                val_acc.update(acc, images.size(0))
                val_precision.update(precision, images.size(0))
                val_recall.update(recall, images.size(0))
                val_f1.update(f1, images.size(0))
        
        # Update scheduler
        scheduler.step(val_losses.avg)
        
        # Print epoch results
        print(f"\n📊 Epoch [{epoch+1}/{config['epochs']}] Results:")
        print(f"   Train - Loss: {train_losses.avg:.4f}, Acc: {train_acc.avg:.4f}")
        print(f"   Val   - Loss: {val_losses.avg:.4f}, Acc: {val_acc.avg:.4f}, "
              f"Precision: {val_precision.avg:.4f}, Recall: {val_recall.avg:.4f}, F1: {val_f1.avg:.4f}")
        
        # Save best model
        if val_acc.avg > best_val_acc:
            best_val_acc = val_acc.avg
            model.save_model(config['model_save_path'])
            print(f"   ✅ Best model saved! (Acc: {best_val_acc:.4f})")
        
        # Save checkpoint
        if (epoch + 1) % 10 == 0:
            checkpoint_path = os.path.join(
                config['checkpoint_dir'], 
                f"checkpoint_epoch{epoch+1}.pt"
            )
            torch.save({
                'epoch': epoch,
                'model_state_dict': model.model.state_dict(),
                'optimizer_state_dict': optimizer.state_dict(),
                'best_acc': best_val_acc,
            }, checkpoint_path)
            print(f"   💾 Checkpoint saved: {checkpoint_path}")
    
    print(f"\n✅ Training complete! Best validation accuracy: {best_val_acc:.4f}")
    print(f"✅ Model saved to {config['model_save_path']}")
    
    return config['model_save_path']


# ============================================
# MODEL VERIFICATION
# ============================================

def verify_mobilenet_model(model_path='models/mobilenetv2_deepfake.pt'):
    """Verify MobileNet model file"""
    
    print("=" * 60)
    print("VERIFYING MOBILENETV2 MODEL")
    print("=" * 60)
    
    # Check if file exists
    if not Path(model_path).exists():
        print(f"❌ Model file not found: {model_path}")
        print("\nPlease run training script first:")
        print("  python training/train_mobilenet.py")
        return False
    
    # Check file size
    size = Path(model_path).stat().st_size / (1024 * 1024)
    print(f"📁 File size: {size:.2f} MB")
    
    try:
        # Initialize model
        model = MobileNetFactory.create_pytorch_model(
            model_size='v2',
            use_custom=True,
            num_classes=2,
            device='cpu'
        )
        
        # Load weights
        model.load_model(model_path)
        print("✅ Model loaded successfully")
        
        # Model info
        params = model.count_parameters()
        print(f"📊 Model parameters: {params:,}")
        
        # Test inference
        print(f"\n🧪 Testing inference speed...")
        
        import time
        import numpy as np
        
        # Create dummy input
        dummy_input = torch.randn(1, 3, 224, 224)
        
        # Warmup
        for _ in range(10):
            with torch.no_grad():
                _ = model.model(dummy_input)
        
        # Benchmark
        num_iterations = 100
        start = time.time()
        
        for _ in range(num_iterations):
            with torch.no_grad():
                output = model.model(dummy_input)
        
        total_time = time.time() - start
        avg_time = total_time / num_iterations * 1000  # ms
        fps = 1000 / avg_time
        
        print(f"   Average inference time: {avg_time:.2f} ms")
        print(f"   Estimated FPS: {fps:.1f}")
        
        # Test prediction
        test_image = np.random.randint(0, 255, (224, 224, 3), dtype=np.uint8)
        result = model.predict(test_image)
        
        print(f"\n📊 Sample prediction:")
        print(f"   Real probability: {result['real_probability']:.4f}")
        print(f"   Fake probability: {result['fake_probability']:.4f}")
        print(f"   Prediction: {result['prediction']}")
        print(f"   Confidence: {result['confidence']:.4f}")
        
        return True
        
    except Exception as e:
        print(f"❌ Error verifying model: {str(e)}")
        import traceback
        traceback.print_exc()
        return False


# ============================================
# MODEL QUANTIZATION (for even faster inference)
# ============================================

def quantize_mobilenet(model_path='models/mobilenetv2_deepfake.pt',
                      quantized_path='models/mobilenetv2_deepfake_quantized.pt'):
    """
    Quantize MobileNet model for even faster inference
    Reduces model size and increases speed
    """
    
    print("=" * 60)
    print("QUANTIZING MOBILENETV2 MODEL")
    print("=" * 60)
    
    try:
        # Load model
        model = MobileNetFactory.create_pytorch_model(
            model_size='v2',
            use_custom=True,
            num_classes=2,
            device='cpu'
        )
        model.load_model(model_path)
        
        print(f"📊 Original model size: {Path(model_path).stat().st_size / (1024*1024):.2f} MB")
        
        # Quantize
        model.model.eval()
        model.model.cpu()
        
        quantized_model = torch.quantization.quantize_dynamic(
            model.model,
            {nn.Linear, nn.Conv2d},
            dtype=torch.qint8
        )
        
        # Save quantized model
        torch.save(quantized_model.state_dict(), quantized_path)
        
        quantized_size = Path(quantized_path).stat().st_size / (1024*1024)
        print(f"✅ Quantized model size: {quantized_size:.2f} MB")
        print(f"   Size reduction: {(1 - quantized_size/(Path(model_path).stat().st_size / (1024*1024)))*100:.1f}%")
        
        # Test speed
        dummy_input = torch.randn(1, 3, 224, 224)
        
        # Original speed
        start = time.time()
        for _ in range(100):
            with torch.no_grad():
                _ = model.model(dummy_input)
        original_time = (time.time() - start) * 10  # ms per inference
        
        # Quantized speed
        start = time.time()
        for _ in range(100):
            with torch.no_grad():
                _ = quantized_model(dummy_input)
        quantized_time = (time.time() - start) * 10  # ms per inference
        
        print(f"\n⚡ Speed comparison:")
        print(f"   Original inference: {original_time:.2f} ms")
        print(f"   Quantized inference: {quantized_time:.2f} ms")
        print(f"   Speedup: {original_time/quantized_time:.2f}x")
        
        return quantized_path
        
    except Exception as e:
        print(f"❌ Quantization error: {str(e)}")
        return None


# ============================================
# MAIN EXECUTION
# ============================================

if __name__ == "__main__":
    import argparse
    
    parser = argparse.ArgumentParser(description='Train/Verify MobileNetV2 Model')
    parser.add_argument('--train', action='store_true', help='Train the model')
    parser.add_argument('--verify', action='store_true', help='Verify existing model')
    parser.add_argument('--quantize', action='store_true', help='Quantize model for faster inference')
    
    args = parser.parse_args()
    
    if args.train:
        train_mobilenet()
    
    if args.verify:
        verify_mobilenet_model()
    
    if args.quantize:
        quantize_mobilenet()
    
    if not any([args.train, args.verify, args.quantize]):
        print("No action specified. Available options:")
        print("  --train     Train the model")
        print("  --verify    Verify existing model")
        print("  --quantize  Quantize model for faster inference")