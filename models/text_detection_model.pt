# models/text_detection_model.pt
"""
Text Detection Model for AI-Generated Content
Detects if text was written by AI (GPT-4, Claude, LLaMA, etc.)
Combines multiple approaches: Perplexity, BERT/RoBERTa classifiers, statistical analysis
This is a binary file that contains the pre-trained weights.
Below is the script to generate this file.
"""

# ============================================
# MODEL DEFINITION (text_detection_model.py)
# ============================================

"""
This model architecture matches the one in app/models/text_detection_model.py
The actual .pt file will be generated by running the training script.
"""


# ============================================
# TRAINING SCRIPT (train_text_detector.py)
# ============================================

```python
# training/train_text_detector.py
"""
Training script for AI-Generated Text Detection Model
Generates text_detection_model.pt file
Trains on human vs AI-generated text datasets
"""

import os
import sys
import json
import torch
import torch.nn as nn
import torch.optim as optim
from torch.utils.data import DataLoader, Dataset
import numpy as np
from pathlib import Path
from collections import Counter
import math

# Add project root to path
sys.path.append(str(Path(__file__).parent.parent))

# NLP imports
import nltk
from nltk.tokenize import word_tokenize, sent_tokenize
from transformers import (
    AutoTokenizer, 
    AutoModelForSequenceClassification,
    RobertaTokenizer,
    RobertaForSequenceClassification,
    BertTokenizer,
    BertForSequenceClassification,
    GPT2Tokenizer,
    GPT2LMHeadModel
)

from app.models.text_detection_model import (
    StatisticalTextAnalyzer,
    PerplexityDetector,
    BERTTextClassifier,
    TextDeepfakeDetector
)


# ============================================
# CUSTOM DATASET
# ============================================

class TextDataset(Dataset):
    """Dataset for AI-generated text detection"""
    
    def __init__(self, texts, labels, tokenizer, max_length=512):
        """
        Args:
            texts: List of text samples
            labels: List of labels (0=human, 1=AI)
            tokenizer: Tokenizer for BERT/RoBERTa
            max_length: Maximum sequence length
        """
        self.texts = texts
        self.labels = labels
        self.tokenizer = tokenizer
        self.max_length = max_length
    
    def __len__(self):
        return len(self.texts)
    
    def __getitem__(self, idx):
        text = self.texts[idx]
        label = self.labels[idx]
        
        # Tokenize
        encoding = self.tokenizer(
            text,
            truncation=True,
            padding='max_length',
            max_length=self.max_length,
            return_tensors='pt'
        )
        
        return {
            'input_ids': encoding['input_ids'].squeeze(0),
            'attention_mask': encoding['attention_mask'].squeeze(0),
            'label': torch.tensor(label, dtype=torch.long)
        }


# ============================================
# CUSTOM NEURAL NETWORK FOR TEXT DETECTION
# ============================================

class TextDeepfakeNN(nn.Module):
    """
    Custom neural network for text deepfake detection
    Combines statistical features with neural embeddings
    """
    
    def __init__(self, 
                 vocab_size=30522,
                 embedding_dim=256,
                 hidden_dim=512,
                 num_classes=2,
                 num_statistical_features=15):
        """
        Initialize custom text deepfake network
        
        Args:
            vocab_size: Vocabulary size
            embedding_dim: Embedding dimension
            hidden_dim: Hidden layer dimension
            num_classes: Number of output classes (2)
            num_statistical_features: Number of statistical features
        """
        super(TextDeepfakeNN, self).__init__()
        
        # Text embedding layer
        self.embedding = nn.Embedding(vocab_size, embedding_dim)
        
        # LSTM for sequence modeling
        self.lstm = nn.LSTM(
            embedding_dim, 
            hidden_dim, 
            num_layers=2,
            batch_first=True,
            bidirectional=True,
            dropout=0.3
        )
        
        # Statistical features processing
        self.statistical_fc = nn.Sequential(
            nn.Linear(num_statistical_features, 128),
            nn.ReLU(),
            nn.Dropout(0.3)
        )
        
        # Combined classifier
        self.classifier = nn.Sequential(
            nn.Linear(hidden_dim * 2 + 128, 512),
            nn.ReLU(),
            nn.Dropout(0.4),
            nn.Linear(512, 256),
            nn.ReLU(),
            nn.Dropout(0.3),
            nn.Linear(256, num_classes)
        )
        
    def forward(self, input_ids, statistical_features):
        # Text embedding path
        embedded = self.embedding(input_ids)
        lstm_out, (hidden, cell) = self.lstm(embedded)
        
        # Use last hidden state (bidirectional concatenation)
        text_features = torch.cat((hidden[-2,:,:], hidden[-1,:,:]), dim=1)
        
        # Statistical path
        stat_features = self.statistical_fc(statistical_features)
        
        # Combine features
        combined = torch.cat((text_features, stat_features), dim=1)
        
        # Classification
        output = self.classifier(combined)
        
        return output


# ============================================
# STATISTICAL FEATURE EXTRACTOR
# ============================================

class StatisticalFeatureExtractor:
    """Extract statistical features from text for the neural network"""
    
    def __init__(self):
        self.analyzer = StatisticalTextAnalyzer()
        
    def extract_features(self, text):
        """Extract numerical features from text"""
        metrics = self.analyzer.analyze(text)
        
        # Convert metrics to feature vector
        features = [
            metrics.word_count / 1000,  # Normalized word count
            metrics.sentence_count / 100,  # Normalized sentence count
            metrics.avg_word_length,
            metrics.avg_sentence_length / 50,  # Normalized
            metrics.vocabulary_richness,
            metrics.hapax_ratio,
            metrics.stopword_ratio,
            metrics.punctuation_ratio,
            metrics.digit_ratio,
            metrics.uppercase_ratio,
            metrics.noun_ratio,
            metrics.verb_ratio,
            metrics.adjective_ratio,
            metrics.adverb_ratio,
            metrics.formality_score
        ]
        
        return torch.tensor(features, dtype=torch.float32)


# ============================================
# TRAINING FUNCTIONS
# ============================================

def train_bert_classifier(train_texts, train_labels, val_texts, val_labels, config):
    """Train BERT/RoBERTa classifier"""
    
    print("\n1️⃣ Training BERT Classifier...")
    
    # Load tokenizer and model
    tokenizer = RobertaTokenizer.from_pretrained('roberta-base')
    model = RobertaForSequenceClassification.from_pretrained(
        'roberta-base',
        num_labels=2
    )
    model.to(config['device'])
    
    # Create datasets
    train_dataset = TextDataset(train_texts, train_labels, tokenizer)
    val_dataset = TextDataset(val_texts, val_labels, tokenizer)
    
    train_loader = DataLoader(
        train_dataset, 
        batch_size=config['batch_size'],
        shuffle=True
    )
    val_loader = DataLoader(
        val_dataset,
        batch_size=config['batch_size'],
        shuffle=False
    )
    
    # Optimizer
    optimizer = optim.AdamW(model.parameters(), lr=config['learning_rate'])
    
    # Training loop
    best_val_acc = 0.0
    bert_model_path = 'models/bert_text_detector.pt'
    
    for epoch in range(config['bert_epochs']):
        # Training
        model.train()
        train_loss = 0.0
        train_correct = 0
        train_total = 0
        
        for batch in train_loader:
            input_ids = batch['input_ids'].to(config['device'])
            attention_mask = batch['attention_mask'].to(config['device'])
            labels = batch['label'].to(config['device'])
            
            optimizer.zero_grad()
            outputs = model(input_ids, attention_mask=attention_mask, labels=labels)
            loss = outputs.loss
            logits = outputs.logits
            
            loss.backward()
            optimizer.step()
            
            train_loss += loss.item()
            _, predicted = torch.max(logits, 1)
            train_total += labels.size(0)
            train_correct += (predicted == labels).sum().item()
        
        train_acc = train_correct / train_total
        
        # Validation
        model.eval()
        val_correct = 0
        val_total = 0
        
        with torch.no_grad():
            for batch in val_loader:
                input_ids = batch['input_ids'].to(config['device'])
                attention_mask = batch['attention_mask'].to(config['device'])
                labels = batch['label'].to(config['device'])
                
                outputs = model(input_ids, attention_mask=attention_mask)
                logits = outputs.logits
                _, predicted = torch.max(logits, 1)
                
                val_total += labels.size(0)
                val_correct += (predicted == labels).sum().item()
        
        val_acc = val_correct / val_total
        
        print(f"   Epoch {epoch+1}/{config['bert_epochs']}: "
              f"Train Loss: {train_loss/len(train_loader):.4f}, "
              f"Train Acc: {train_acc:.4f}, Val Acc: {val_acc:.4f}")
        
        # Save best model
        if val_acc > best_val_acc:
            best_val_acc = val_acc
            torch.save(model.state_dict(), bert_model_path)
            print(f"   ✅ Best BERT model saved (Acc: {val_acc:.4f})")
    
    return bert_model_path, best_val_acc


def train_perplexity_detector(train_texts, train_labels, val_texts, val_labels, config):
    """Train perplexity-based detector"""
    
    print("\n2️⃣ Setting up Perplexity Detector...")
    
    # Initialize perplexity detector
    perplexity_detector = PerplexityDetector(
        model_name='gpt2',
        device=config['device']
    )
    
    # Calculate perplexity thresholds
    train_perplexities = []
    for text in train_texts:
        ppl = perplexity_detector.calculate_perplexity(text[:1000])  # Limit length
        train_perplexities.append(ppl)
    
    # Find optimal threshold
    from sklearn.metrics import accuracy_score
    
    thresholds = np.linspace(20, 100, 50)
    best_threshold = 50
    best_acc = 0
    
    for threshold in thresholds:
        preds = [1 if ppl < threshold else 0 for ppl in train_perplexities]
        acc = accuracy_score(train_labels, preds)
        if acc > best_acc:
            best_acc = acc
            best_threshold = threshold
    
    print(f"   Optimal perplexity threshold: {best_threshold:.2f}")
    print(f"   Training accuracy: {best_acc:.4f}")
    
    # Save threshold
    perplexity_config = {
        'threshold': best_threshold,
        'model_name': 'gpt2'
    }
    
    perplexity_path = 'models/perplexity_config.json'
    with open(perplexity_path, 'w') as f:
        json.dump(perplexity_config, f)
    
    return perplexity_path, best_threshold


def train_custom_nn(train_texts, train_labels, val_texts, val_labels, config):
    """Train custom neural network with statistical features"""
    
    print("\n3️⃣ Training Custom Neural Network...")
    
    # Initialize feature extractor
    feature_extractor = StatisticalFeatureExtractor()
    
    # Extract statistical features
    train_features = []
    val_features = []
    
    print("   Extracting statistical features...")
    for text in train_texts:
        features = feature_extractor.extract_features(text)
        train_features.append(features)
    
    for text in val_texts:
        features = feature_extractor.extract_features(text)
        val_features.append(features)
    
    # Tokenize texts
    tokenizer = AutoTokenizer.from_pretrained('bert-base-uncased')
    
    train_encodings = tokenizer(
        train_texts,
        truncation=True,
        padding=True,
        max_length=512,
        return_tensors='pt'
    )
    
    val_encodings = tokenizer(
        val_texts,
        truncation=True,
        padding=True,
        max_length=512,
        return_tensors='pt'
    )
    
    # Create dataset
    class CustomTextDataset(Dataset):
        def __init__(self, encodings, features, labels):
            self.encodings = encodings
            self.features = features
            self.labels = labels
        
        def __getitem__(self, idx):
            return {
                'input_ids': self.encodings['input_ids'][idx],
                'attention_mask': self.encodings['attention_mask'][idx],
                'features': self.features[idx],
                'label': self.labels[idx]
            }
        
        def __len__(self):
            return len(self.labels)
    
    train_dataset = CustomTextDataset(
        train_encodings,
        train_features,
        torch.tensor(train_labels)
    )
    
    val_dataset = CustomTextDataset(
        val_encodings,
        val_features,
        torch.tensor(val_labels)
    )
    
    train_loader = DataLoader(
        train_dataset,
        batch_size=config['batch_size'],
        shuffle=True
    )
    
    val_loader = DataLoader(
        val_dataset,
        batch_size=config['batch_size'],
        shuffle=False
    )
    
    # Initialize model
    model = TextDeepfakeNN(
        vocab_size=tokenizer.vocab_size,
        num_statistical_features=15
    )
    model.to(config['device'])
    
    # Loss and optimizer
    criterion = nn.CrossEntropyLoss()
    optimizer = optim.Adam(model.parameters(), lr=config['learning_rate'])
    
    # Training loop
    best_val_acc = 0.0
    nn_model_path = 'models/text_detection_model.pt'
    
    for epoch in range(config['nn_epochs']):
        # Training
        model.train()
        train_loss = 0.0
        train_correct = 0
        train_total = 0
        
        for batch in train_loader:
            input_ids = batch['input_ids'].to(config['device'])
            features = batch['features'].to(config['device'])
            labels = batch['label'].to(config['device'])
            
            optimizer.zero_grad()
            outputs = model(input_ids, features)
            loss = criterion(outputs, labels)
            
            loss.backward()
            optimizer.step()
            
            train_loss += loss.item()
            _, predicted = torch.max(outputs, 1)
            train_total += labels.size(0)
            train_correct += (predicted == labels).sum().item()
        
        train_acc = train_correct / train_total
        
        # Validation
        model.eval()
        val_correct = 0
        val_total = 0
        
        with torch.no_grad():
            for batch in val_loader:
                input_ids = batch['input_ids'].to(config['device'])
                features = batch['features'].to(config['device'])
                labels = batch['label'].to(config['device'])
                
                outputs = model(input_ids, features)
                _, predicted = torch.max(outputs, 1)
                
                val_total += labels.size(0)
                val_correct += (predicted == labels).sum().item()
        
        val_acc = val_correct / val_total
        
        print(f"   Epoch {epoch+1}/{config['nn_epochs']}: "
              f"Train Loss: {train_loss/len(train_loader):.4f}, "
              f"Train Acc: {train_acc:.4f}, Val Acc: {val_acc:.4f}")
        
        # Save best model
        if val_acc > best_val_acc:
            best_val_acc = val_acc
            torch.save({
                'model_state_dict': model.state_dict(),
                'config': {
                    'vocab_size': tokenizer.vocab_size,
                    'num_statistical_features': 15,
                    'num_classes': 2
                },
                'best_acc': best_val_acc
            }, nn_model_path)
            print(f"   ✅ Best model saved (Acc: {val_acc:.4f})")
    
    return nn_model_path, best_val_acc


# ============================================
# MAIN TRAINING FUNCTION
# ============================================

def train_text_detector():
    """Main training function for text detection model"""
    
    # Configuration
    config = {
        'batch_size': 16,
        'learning_rate': 2e-5,
        'bert_epochs': 5,
        'nn_epochs': 20,
        'device': 'cuda' if torch.cuda.is_available() else 'cpu',
        'model_save_path': 'models/text_detection_model.pt',
        'data_path': 'datasets/text_data/'
    }
    
    print("=" * 60)
    print("TRAINING TEXT DEEPFAKE DETECTOR")
    print("=" * 60)
    print(f"Configuration: {config}")
    
    # TODO: Load your datasets
    print("\n⚠️  Please update the training script with your dataset paths")
    print("Example dataset structure:")
    print("""
    datasets/text_data/
    ├── train/
    │   ├── human.txt
    │   └── ai.txt
    └── val/
        ├── human.txt
        └── ai.txt
    """)
    
    # For demonstration, create dummy data
    print("\n📊 Creating dummy dataset for demonstration...")
    
    # Sample human-like text
    human_samples = [
        "I went to the store yesterday and bought some groceries. The weather was nice.",
        "My friend called me last night and we talked for hours about our plans.",
        "The movie was really good! I especially liked the ending.",
        "I need to finish this project by Friday, but I'm not sure if I'll make it.",
        "Have you seen my keys? I can't find them anywhere."
    ] * 100
    
    # Sample AI-like text
    ai_samples = [
        "In conclusion, the implementation of artificial intelligence in healthcare presents numerous advantages for patient care.",
        "Furthermore, it is important to consider the ethical implications of such technologies.",
        "Additionally, there are several factors that contribute to the effectiveness of this approach.",
        "Moreover, the integration of these systems requires careful planning and consideration.",
        "It should be noted that while these benefits are substantial, there are also challenges to address."
    ] * 100
    
    # Create labels (0=human, 1=AI)
    train_texts = human_samples[:80] + ai_samples[:80]
    train_labels = [0]*80 + [1]*80
    
    val_texts = human_samples[80:100] + ai_samples[80:100]
    val_labels = [0]*20 + [1]*20
    
    print(f"   Train samples: {len(train_texts)}")
    print(f"   Val samples: {len(val_texts)}")
    
    # Train BERT classifier
    bert_path, bert_acc = train_bert_classifier(
        train_texts, train_labels,
        val_texts, val_labels,
        config
    )
    
    # Train perplexity detector
    perplexity_path, ppl_threshold = train_perplexity_detector(
        train_texts, train_labels,
        val_texts, val_labels,
        config
    )
    
    # Train custom neural network
    nn_path, nn_acc = train_custom_nn(
        train_texts, train_labels,
        val_texts, val_labels,
        config
    )
    
    # Save ensemble configuration
    ensemble_config = {
        'bert_model': str(bert_path),
        'perplexity_config': str(perplexity_path),
        'perplexity_threshold': ppl_threshold,
        'nn_model': str(nn_path),
        'bert_accuracy': bert_acc,
        'nn_accuracy': nn_acc,
        'weights': {
            'bert': 0.4,
            'perplexity': 0.3,
            'nn': 0.3
        }
    }
    
    with open('models/text_ensemble_config.json', 'w') as f:
        json.dump(ensemble_config, f, indent=2)
    
    print("\n" + "=" * 60)
    print("✅ TRAINING COMPLETE!")
    print("=" * 60)
    print(f"\n📊 Model Performance:")
    print(f"   BERT Classifier Accuracy: {bert_acc:.4f}")
    print(f"   Perplexity Detector Threshold: {ppl_threshold:.2f}")
    print(f"   Custom NN Accuracy: {nn_acc:.4f}")
    print(f"\n💾 Models saved:")
    print(f"   - {bert_path}")
    print(f"   - {perplexity_path}")
    print(f"   - {nn_path}")
    print(f"   - models/text_ensemble_config.json")
    
    return nn_path


# ============================================
# MODEL VERIFICATION
# ============================================

def verify_text_model(model_path='models/text_detection_model.pt'):
    """Verify text detection model file"""
    
    print("=" * 60)
    print("VERIFYING TEXT DETECTION MODEL")
    print("=" * 60)
    
    # Check if file exists
    if not Path(model_path).exists():
        print(f"❌ Model file not found: {model_path}")
        print("\nPlease run training script first:")
        print("  python training/train_text_detector.py")
        return False
    
    # Check file size
    size = Path(model_path).stat().st_size / (1024 * 1024)
    print(f"📁 File size: {size:.2f} MB")
    
    try:
        # Load checkpoint
        checkpoint = torch.load(model_path, map_location='cpu')
        
        print("✅ Model loaded successfully")
        
        if 'model_state_dict' in checkpoint:
            print(f"   Contains model state dict")
        if 'config' in checkpoint:
            print(f"   Config: {checkpoint['config']}")
        if 'best_acc' in checkpoint:
            print(f"   Best accuracy: {checkpoint['best_acc']:.4f}")
        
        # Test with sample texts
        print(f"\n🧪 Testing with sample texts...")
        
        # Initialize the full detector
        from app.models.text_detection_model import TextDetectorFactory
        
        detector = TextDetectorFactory.create_lightweight_detector()
        
        # Test human text
        human_text = "I went to the store yesterday and bought some milk and bread. The cashier was very friendly."
        result = detector.detect(human_text)
        
        print(f"\n📊 Human text sample:")
        print(f"   Text: {human_text[:50]}...")
        print(f"   Prediction: {result.prediction}")
        print(f"   AI Probability: {result.ai_probability:.4f}")
        print(f"   Confidence: {result.confidence:.4f}")
        
        # Test AI text
        ai_text = "In conclusion, it is important to note that there are several factors to consider when evaluating the implementation of such systems. Furthermore, the integration of these technologies requires careful planning and consideration of various parameters."
        result = detector.detect(ai_text)
        
        print(f"\n📊 AI text sample:")
        print(f"   Text: {ai_text[:50]}...")
        print(f"   Prediction: {result.prediction}")
        print(f"   AI Probability: {result.ai_probability:.4f}")
        print(f"   Confidence: {result.confidence:.4f}")
        
        return True
        
    except Exception as e:
        print(f"❌ Error verifying model: {str(e)}")
        import traceback
        traceback.print_exc()
        return False


# ============================================
# MODEL EXPORT (for deployment)
# ============================================

def export_onnx(model_path='models/text_detection_model.pt',
                onnx_path='models/text_detection_model.onnx'):
    """Export model to ONNX format for deployment"""
    
    print("=" * 60)
    print("EXPORTING TEXT DETECTION MODEL TO ONNX")
    print("=" * 60)
    
    try:
        import torch.onnx
        
        # Load checkpoint
        checkpoint = torch.load(model_path, map_location='cpu')
        
        # Recreate model
        config = checkpoint.get('config', {
            'vocab_size': 30522,
            'num_statistical_features': 15,
            'num_classes': 2
        })
        
        model = TextDeepfakeNN(
            vocab_size=config['vocab_size'],
            num_statistical_features=config['num_statistical_features']
        )
        model.load_state_dict(checkpoint['model_state_dict'])
        model.eval()
        
        # Create dummy inputs
        dummy_input_ids = torch.randint(0, config['vocab_size'], (1, 512))
        dummy_features = torch.randn(1, config['num_statistical_features'])
        
        # Export to ONNX
        torch.onnx.export(
            model,
            (dummy_input_ids, dummy_features),
            onnx_path,
            input_names=['input_ids', 'statistical_features'],
            output_names=['output'],
            dynamic_axes={
                'input_ids': {0: 'batch_size'},
                'statistical_features': {0: 'batch_size'},
                'output': {0: 'batch_size'}
            },
            opset_version=11
        )
        
        print(f"✅ Model exported to {onnx_path}")
        
        # Show file size
        size = Path(onnx_path).stat().st_size / (1024 * 1024)
        print(f"📁 ONNX file size: {size:.2f} MB")
        
        return onnx_path
        
    except Exception as e:
        print(f"❌ Export error: {str(e)}")
        return None


# ============================================
# MAIN EXECUTION
# ============================================

if __name__ == "__main__":
    import argparse
    
    parser = argparse.ArgumentParser(description='Train/Verify Text Detection Model')
    parser.add_argument('--train', action='store_true', help='Train the model')
    parser.add_argument('--verify', action='store_true', help='Verify existing model')
    parser.add_argument('--export', action='store_true', help='Export to ONNX format')
    
    args = parser.parse_args()
    
    if args.train:
        train_text_detector()
    
    if args.verify:
        verify_text_model()
    
    if args.export:
        export_onnx()
    
    if not any([args.train, args.verify, args.export]):
        print("No action specified. Available options:")
        print("  --train     Train the model")
        print("  --verify    Verify existing model")
        print("  --export    Export to ONNX format")